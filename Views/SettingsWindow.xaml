<Window x:Class="WindowsPinboard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pinboard Settings"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1F1F23"
        Foreground="#FFEDEFF2"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEDEFF2"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF26262C"/>
            <Setter Property="Foreground" Value="#FFEDEFF2"/>
            <Setter Property="BorderBrush" Value="#FF34343B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF26262C"/>
            <Setter Property="Foreground" Value="#FF111111"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEDEFF2"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF34343B"/>
            <Setter Property="Foreground" Value="#FFEDEFF2"/>
            <Setter Property="BorderBrush" Value="#FF44444B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <StackPanel Margin="18">
        <TextBlock Text="Hotkey" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock Text="Click below and press a key combination (must include a modifier)."
                   Foreground="#FFB6BBC4" FontSize="11" TextWrapping="Wrap"/>
        <Border Background="#FF26262C" BorderBrush="#FF34343B" BorderThickness="1"
                Padding="8,6" Margin="0,4,0,8" CornerRadius="3">
            <TextBox x:Name="HotkeyBox" IsReadOnly="True" BorderThickness="0"
                     Background="Transparent" Foreground="#FFEDEFF2"
                     Padding="0" PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     ToolTip="Click and press a key combination"/>
        </Border>

        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Edge" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="EdgeCombo">
                    <ComboBoxItem Content="Right" Tag="Right"/>
                    <ComboBoxItem Content="Left" Tag="Left"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="Monitor" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="MonitorCombo" DisplayMemberPath="DisplayName"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Sidebar width (px)" FontWeight="SemiBold" FontSize="14"/>
                <TextBox x:Name="WidthBox"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="Handle thickness (px)" FontWeight="SemiBold" FontSize="14"/>
                <TextBox x:Name="HandleBox"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,2"/>
        <CheckBox x:Name="HoverCheck" Content="Open on hover"/>
        <CheckBox x:Name="AppBarCheck" Content="Reserve screen edge (apps won't cover the handle)"
                  ToolTip="Registers the sliver as a Windows AppBar so maximized apps respect it."/>
        <CheckBox x:Name="AutostartCheck" Content="Start with Windows"/>
        <CheckBox x:Name="GameModeCheck" Content="Pause when a fullscreen game is running"
                  ToolTip="Hides the sidebar and disables the hotkey while a fullscreen game or presentation is active."/>

        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Hover delay (ms)"/>
                <TextBox x:Name="HoverDelayBox"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="Auto-hide delay (ms)"/>
                <TextBox x:Name="AutoHideBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" IsCancel="True" Click="OnCancel"/>
            <Button Content="Save" IsDefault="True" Click="OnSave"/>
        </StackPanel>
    </StackPanel>
</Window>
